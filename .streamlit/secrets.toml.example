# Ambas claves son OPCIONALES y gratuitas:
#  - Sin ENTSOE_API_KEY la app usa Energy-Charts (Fraunhofer, sin clave) para la
#    generación en vivo; la clave solo añade ENTSO-E como respaldo.
#  - Sin OPENAQ_API_KEY se desactiva la capa de calidad del aire en vivo (PM2.5).
#    Consíguela gratis registrándote en https://openaq.org.
ENTSOE_API_KEY = "tu-clave-de-entsoe"
OPENAQ_API_KEY = "tu-clave-de-openaq"
